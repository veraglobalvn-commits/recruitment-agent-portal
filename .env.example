# Supabase – authentication & database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OCR & AI – passport/business-license extraction
OCR_SPACE_API_KEY=your-ocr-space-api-key
OPENAI_API_KEY=your-openai-api-key

# AI translation – OpenRouter (nvidia/llama-3.1-nemotron-ultra-253b-v1:free)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# n8n webhooks – Lark/Bitable sync
NEXT_PUBLIC_N8N_UPLOAD_URL=https://your-n8n-instance.com/webhook/upload-passport
NEXT_PUBLIC_N8N_VIDEO_UPDATE_URL=https://your-n8n-instance.com/webhook/update-video

# n8n webhooks – Telegram notifications
NEXT_PUBLIC_N8N_VIDEO_NOTIFY_URL=https://your-n8n-instance.com/webhook/telegram-video-notify

# n8n webhook – PDF recruitment document generation
NEXT_PUBLIC_N8N_RECRUITMENT_DOC_URL=https://your-n8n-instance.com/webhook/recruitment-doc

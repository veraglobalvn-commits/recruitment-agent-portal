      "name": "Select Template URL",
      "parameters": {
        "jsCode": "// Select template URL based on contract type\nconst contractType = $('Fetch Contract Request').first().json.contract_type;\nconst templateUrl = contractType === 'advanced' \n  ? $env.NEXT_PUBLIC_CONTRACT_ADVANCED_TEMPLATE_URL \n  : $env.NEXT_PUBLIC_CONTRACT_BASIC_TEMPLATE_URL;\n\nreturn { json: { template_url: templateUrl } };"

    {
      "id": "validate-required-fields",
      "name": "Validate Required Fields",
      "parameters": {
        "jsCode": "// Validate required fields for Contract\nconst order = $('Fetch Order Data').first().json;\nconst company = $('Fetch Company Data').first().json;\nconst candidate = $('Fetch Candidate Data').first().json;\n\nconst missing = [];\n\nif (!company.company_name) missing.push('company_name');\nif (!company.tax_code) missing.push('tax_code');\nif (!company.legal_rep) missing.push('legal_rep');\nif (!company.legal_rep_title) missing.push('legal_rep_title');\nif (!company.address) missing.push('address');\nif (!company.phone) missing.push('phone');\nif (!company.business_reg_authority) missing.push('business_reg_authority');\nif (!company.business_reg_date) missing.push('business_reg_date');\nif (!order.total_labor || Number(order.total_labor) <= 0) missing.push('total_labor');\nif (!order.service_fee_per_person || Number(order.service_fee_per_person) <= 0) missing.push('service_fee_per_person');\nif (!order.total_fee_vn || Number(order.total_fee_vn) <= 0) missing.push('total_fee_vn');\n\nif (missing.length > 0) {\n  throw new Error(`Missing required fields: ${missing.join(', ')}`);\n}\n\nreturn { json: { valid: true } };"
      },
      "position": [
        944,
        -80
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },

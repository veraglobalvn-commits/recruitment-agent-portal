        "jsCode": "// Determine table name based on entity_type\nconst entityType = $input.first().json.entity_type;\nconst tableName = entityType === 'company' ? 'companies' : 'orders';\n\nreturn {\n  json: {\n    table_name: tableName,\n    entity_type: entityType,\n    entity_id: $input.first().json.entity_id,\n    fields_to_translate: $input.first().json.fields_to_translate\n  }\n};"

{
  "name": "[Portal API] Translate Entity",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const entityType = $('Determine Table Name1').first().json.entity_type;\nconst fieldsToTranslate = $('Determine Table Name1').first().json.fields_to_translate;\nconst entityData = $input.first().json;\n\nconst jsonToTranslate = {};\nfieldsToTranslate.forEach(field => {\n  const value = entityData[field] || '';\n  let destKey = field;\n  if (entityType === 'company') {\n    if (field === 'company_name') destKey = 'en_company_name';\n    else if (field === 'industry') destKey = 'en_industry';\n    else if (field === 'business_type') destKey = 'en_business_type';\n    else if (field === 'address') destKey = 'en_address';\n    else if (field === 'legal_rep') destKey = 'en_legal_rep';\n    else if (field === 'legal_rep_title') destKey = 'en_title';\n  } else {\n    destKey = field + '_en';\n  }\n  jsonToTranslate[destKey] = value;\n});\n\nconst prompt = `Translate the Vietnamese values in this JSON object to English. Return ONLY the translated JSON with the EXACT same keys:\n\n${JSON.stringify(jsonToTranslate, null, 2)}`;\n\nreturn { json: { prompt } };"
      },

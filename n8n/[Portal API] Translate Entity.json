      "parameters": {
        "jsCode": "const content = $input.first().json.message?.content || $input.first().json.choices?.[0]?.message?.content || $input.first().json.output || $input.first().json.text;\nlet translatedData;\ntry {\n  translatedData = JSON.parse(content);\n} catch (e) {\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (match) translatedData = JSON.parse(match[0]);\n  else throw new Error('Could not parse JSON');\n}\nreturn { json: translatedData };"
      },

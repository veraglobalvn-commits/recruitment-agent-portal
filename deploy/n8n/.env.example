# n8n Docker environment template
# Copy thành .env, điền giá trị thật, chmod 600 .env
# KHÔNG commit file .env (chỉ commit .env.example)

# ─── n8n Core ───────────────────────────────────────────────────────────────
# Phải khớp với domain + protocol thật để webhook URL generate đúng
N8N_HOST=portal.veraglobal.vn
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://portal.veraglobal.vn/

# Key mã hoá credentials trong DB — đổi lần đầu, KHÔNG đổi sau khi đã có data
N8N_ENCRYPTION_KEY=change_me_random_32_chars_min

# ─── Auth (basic auth cho n8n UI) ────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password

# ─── Database (mặc định SQLite — đủ cho production nhỏ) ──────────────────────
# Nếu muốn PostgreSQL, bỏ comment khối dưới + đổi DB_TYPE
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=127.0.0.1
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=change_me

# ─── Timezone ────────────────────────────────────────────────────────────────
GENERIC_TIMEZONE=Asia/Dhaka
TZ=Asia/Dhaka

# ─── INFRA-005: Self-hosted telegram-bot-api ─────────────────────────────────
# Append 2 dòng này vào .env SAU KHI đã có giá trị n8n ở trên
# (hoặc chạy migrate.sh — tự động append từ env-snippet.txt)
#
# telegram-bot-api chạy cùng mạng tg_net → gọi qua service name
TELEGRAM_BOT_API_BASE_URL=http://telegram-bot-api:8081
# Public URL của portal để agent click xem video/ảnh (nginx proxy → local tg-bot-api)
TELEGRAM_PUBLIC_FILE_BASE=https://portal.veraglobal.vn/tg-media
